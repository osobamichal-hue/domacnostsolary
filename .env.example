# IP adresa střídače GoodWe ve vaší LAN (UDP 8899)
GOODWE_HOST=192.168.1.14

# Interval dotazování v ms (doporučeno 10000–60000 podle stability SEMS)
POLL_INTERVAL_MS=10000

# Odhadovaná výkupní cena za kWh pro výpočet „příjmu“ (EUR)
FEED_IN_EUR_PER_KWH=0.22

# Port HTTP serveru (změna vyžaduje restart Node; UI nastavení ji nemění)
PORT=3000

# Trvalé nastavení lze měnit i v rozhraní Nastavení → ukládá se do data/app-config.json
