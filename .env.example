# IP adresa střídače GoodWe ve vaší LAN (UDP 8899)
GOODWE_HOST=192.168.1.14

# Interval dotazování v ms (doporučeno 10000–60000 podle stability SEMS)
POLL_INTERVAL_MS=10000

# Odhadovaná výkupní cena za kWh pro výpočet „příjmu“ (Kč)
FEED_IN_CZK_PER_KWH=5.50

# Port HTTP serveru (změna vyžaduje restart Node; UI nastavení ji nemění)
PORT=3000

# MySQL / MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=mysql
DB_NAME=homeapp

# Volitelně: cesta k home-assistant_v2.db z rozbalené zálohy HA (jinak scripts/ha_import/data/home-assistant_v2.db)
# HA_SQLITE_PATH=

# Volitelné: vyčítání druhého webu v LAN (Playwright) — viz python/fetch_lan_web.py a python/requirements-lan.txt
# LAN_WEB_ENABLED=0
# LAN_WEB_BASE_URL=http://192.168.5.54
# LAN_WEB_USER=
# LAN_WEB_PASSWORD=
# LAN_WEB_LOGIN_PATH=#/login
# LAN_WEB_DATA_PATH=#/devices
# Druhá stránka (výchozí #/ přehled); vypnutí: LAN_WEB_AUTO_ALT_DASHBOARD=0
# LAN_WEB_ALT_PATH=#/
# LAN_WEB_AUTO_ALT_DASHBOARD=1
# Max. čas běhu Playwright z Node (ms), pak kill procesu — aby neblokoval další dotazy
# LAN_WEB_NODE_TIMEOUT_MS=120000

# Trvalé nastavení lze měnit i v rozhraní Nastavení → ukládá se do data/app-config.json
